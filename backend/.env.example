# Database (async driver). docker-compose overrides host to "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meowindex

# AI scraper credentials — set ONE of these. Anthropic takes precedence.
# Anthropic (default model claude-haiku-4-5): https://console.anthropic.com
ANTHROPIC_API_KEY=
# Google Gemini (default model gemini-2.5-flash): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides:
# SCRAPER_PROVIDER=anthropic|gemini (default: anthropic if its key is set)

# Shared secret required in the X-API-Key header to trigger POST /api/v1/scrape.
SCRAPE_API_KEY=change-me

# Optional: override the Gemini model used by the scraper.
# SCRAPER_MODEL=gemini-2.5-flash
