# Database (async driver). docker-compose overrides host to "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meowindex

# Google Gemini API key for the AI scraper agent.
# Get one for free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Shared secret required in the X-API-Key header to trigger POST /api/v1/scrape.
SCRAPE_API_KEY=change-me

# Optional: override the Gemini model used by the scraper.
# SCRAPER_MODEL=gemini-2.5-flash
